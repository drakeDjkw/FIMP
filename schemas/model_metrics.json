{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ModelMetrics",
  "type": "object",
  "properties": {
    "model": { "type": "string" },
    "metric": { "type": "string" },
    "value": { "type": "number" },
    "unit": { "type": "string" },
    "last_trained": { "type": "string", "format": "date-time" }
  },
  "required": ["model", "metric", "value"]
}
